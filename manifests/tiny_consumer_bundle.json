{
  "manifest_version": 1,
  "bundle_type": "tiny_consumer_bundle",
  "source_inputs": [
    {
      "name": "tos_text_chunk_map",
      "repo": "aoa-kag",
      "path": "generated/tos_text_chunk_map.min.json",
      "role": "generated_surface"
    },
    {
      "name": "tos_retrieval_axis_pack",
      "repo": "aoa-kag",
      "path": "generated/tos_retrieval_axis_pack.min.json",
      "role": "generated_surface"
    },
    {
      "name": "federation_spine",
      "repo": "aoa-kag",
      "path": "generated/federation_spine.min.json",
      "role": "generated_surface"
    },
    {
      "name": "cross_source_node_projection",
      "repo": "aoa-kag",
      "path": "generated/cross_source_node_projection.min.json",
      "role": "generated_surface"
    },
    {
      "name": "consumer_guide",
      "repo": "aoa-kag",
      "path": "docs/CONSUMER_GUIDE.md",
      "role": "consumer_doc"
    },
    {
      "name": "counterpart_consumer_contract_doc",
      "repo": "aoa-kag",
      "path": "docs/COUNTERPART_CONSUMER_CONTRACT.md",
      "role": "counterpart_contract"
    },
    {
      "name": "counterpart_consumer_contract_example",
      "repo": "aoa-kag",
      "path": "examples/counterpart_consumer_contract.example.json",
      "role": "counterpart_contract"
    }
  ],
  "bundle_order": [
    "tos_text_chunk_map",
    "tos_retrieval_axis_pack",
    "federation_spine",
    "cross_source_node_projection",
    "consumer_guide",
    "counterpart_consumer_contract_doc",
    "counterpart_consumer_contract_example"
  ],
  "deferred_counterpart": {
    "surface_id": "AOA-K-0008",
    "surface_status": "planned",
    "posture": "planned_contract_only",
    "allowed_refs": [
      "docs/COUNTERPART_CONSUMER_CONTRACT.md",
      "examples/counterpart_consumer_contract.example.json",
      "docs/COUNTERPART_EDGE_CONTRACTS.md",
      "examples/counterpart_edge_view.example.json"
    ],
    "forbidden_active_payload_refs": [
      "examples/counterpart_edge_view.example.json"
    ],
    "forbidden_interpretations": [
      "active_retrieval_payload",
      "active_projection_payload"
    ]
  },
  "output_paths": {
    "full": "generated/tiny_consumer_bundle.json",
    "min": "generated/tiny_consumer_bundle.min.json"
  }
