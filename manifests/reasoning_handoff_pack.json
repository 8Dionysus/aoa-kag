{
  "manifest_version": 1,
  "pack_type": "reasoning_handoff_pack",
  "source_root_envs": {
    "aoa-playbooks": "AOA_PLAYBOOKS_ROOT",
    "aoa-evals": "AOA_EVALS_ROOT",
    "aoa-memo": "AOA_MEMO_ROOT",
    "aoa-agents": "AOA_AGENTS_ROOT"
  },
  "source_inputs": [
    {
      "name": "reasoning_handoff_doc",
      "repo": "aoa-kag",
      "path": "docs/REASONING_HANDOFF.md",
      "role": "kag_guardrail_doc"
    },
    {
      "name": "reasoning_handoff_schema",
      "repo": "aoa-kag",
      "path": "schemas/reasoning-handoff-guardrail.schema.json",
      "role": "kag_guardrail_schema"
    },
    {
      "name": "counterpart_consumer_contract_doc",
      "repo": "aoa-kag",
      "path": "docs/COUNTERPART_CONSUMER_CONTRACT.md",
      "role": "kag_guardrail_doc"
    },
    {
      "name": "counterpart_consumer_contract_schema",
      "repo": "aoa-kag",
      "path": "schemas/counterpart-consumer-contract.schema.json",
      "role": "kag_guardrail_schema"
    },
    {
      "name": "counterpart_consumer_contract_example",
      "repo": "aoa-kag",
      "path": "examples/counterpart_consumer_contract.example.json",
      "role": "kag_guardrail_example"
    },
    {
      "name": "counterpart_federation_exposure_review_doc",
      "repo": "aoa-kag",
      "path": "docs/COUNTERPART_FEDERATION_EXPOSURE_REVIEW.md",
      "role": "kag_guardrail_doc"
    },
    {
      "name": "artifact_to_verdict_hook_schema",
      "repo": "aoa-evals",
      "path": "schemas/artifact-to-verdict-hook.schema.json",
      "role": "eval_hook_schema"
    },
    {
      "name": "aoa_p_0008_playbook",
      "repo": "aoa-playbooks",
      "path": "playbooks/long-horizon-model-tier-orchestra/PLAYBOOK.md",
      "role": "playbook_doc"
    },
    {
      "name": "aoa_p_0008_hook",
      "repo": "aoa-evals",
      "path": "examples/artifact_to_verdict_hook.long-horizon-model-tier-orchestra.example.json",
      "role": "eval_hook_fixture"
    },
    {
      "name": "aoa_p_0009_playbook",
      "repo": "aoa-playbooks",
      "path": "playbooks/restartable-inquiry-loop/PLAYBOOK.md",
      "role": "playbook_doc"
    },
    {
      "name": "aoa_p_0009_hook",
      "repo": "aoa-evals",
      "path": "examples/artifact_to_verdict_hook.restartable-inquiry-loop.example.json",
      "role": "eval_hook_fixture"
    },
    {
      "name": "checkpoint_to_memory_contract",
      "repo": "aoa-memo",
      "path": "examples/checkpoint_to_memory_contract.example.json",
      "role": "memo_contract_fixture"
    },
    {
      "name": "inquiry_checkpoint_schema",
      "repo": "aoa-memo",
      "path": "schemas/inquiry_checkpoint.schema.json",
      "role": "memo_schema"
    },
    {
      "name": "witness_trace_contract",
      "repo": "aoa-memo",
      "path": "docs/WITNESS_TRACE_CONTRACT.md",
      "role": "memo_doc"
    },
    {
      "name": "witness_trace_schema",
      "repo": "aoa-memo",
      "path": "schemas/witness-trace.schema.json",
      "role": "memo_schema"
    }
  ],
  "scenario_bindings": [
    {
      "scenario_ref": "AOA-P-0008",
      "playbook_input": "aoa_p_0008_playbook",
      "eval_hook_input": "aoa_p_0008_hook",
      "memo_contract_inputs": [
        "checkpoint_to_memory_contract"
      ],
      "continuity_input": null,
      "optional_trace_inputs": [
        "witness_trace_contract",
        "witness_trace_schema"
      ]
    },
    {
      "scenario_ref": "AOA-P-0009",
      "playbook_input": "aoa_p_0009_playbook",
      "eval_hook_input": "aoa_p_0009_hook",
      "memo_contract_inputs": [
        "checkpoint_to_memory_contract"
      ],
      "continuity_input": "inquiry_checkpoint_schema",
      "optional_trace_inputs": []
    }
  ],
  "output_paths": {
    "full": "generated/reasoning_handoff_pack.json",
    "min": "generated/reasoning_handoff_pack.min.json"
  },
  "bounded_output_contract": {
    "source_trace_required": true,
    "source_replacement": "forbidden",
    "routing_ownership": "forbidden",
    "memory_truth_ownership": "forbidden",
    "canon_authorship": "forbidden",
    "verdict_ownership": "forbidden"
  }
}
