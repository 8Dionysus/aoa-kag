{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/source-owned-export-dependencies.schema.json",
  "title": "AoA KAG source-owned export dependency manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "contract_type",
    "dependencies"
  ],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "contract_type": {
      "type": "string",
      "const": "source_owned_export_dependencies"
    },
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dependency_id",
          "repo",
          "path",
          "expected_owner_repo",
          "expected_kind",
          "expected_object_id",
          "required_fields",
          "entry_surface",
          "consumed_by"
        ],
        "properties": {
          "dependency_id": {
            "type": "string",
            "minLength": 3
          },
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "path": {
            "type": "string",
            "minLength": 3
          },
          "expected_owner_repo": {
            "type": "string",
            "minLength": 2
          },
          "expected_kind": {
            "type": "string",
            "minLength": 3
          },
          "expected_object_id": {
            "type": "string",
            "minLength": 3
          },
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "entry_surface": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repo",
              "path",
              "match_key",
              "match_value"
            ],
            "properties": {
              "repo": {
                "type": "string",
                "minLength": 2
              },
              "path": {
                "type": "string",
                "minLength": 3
              },
              "match_key": {
                "type": "string",
                "minLength": 1
              },
              "match_value": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "consumed_by": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^AOA-K-[0-9]{4}$"
            }
          }
        }
      }
    }
  }
}
