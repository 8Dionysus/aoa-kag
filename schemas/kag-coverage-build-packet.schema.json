{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss.org/schemas/kag-coverage-build-packet.schema.json",
  "title": "KAG coverage build packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cache_key",
    "payload_digest",
    "coverage"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa-kag-coverage-build-packet-v1"
    },
    "cache_key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "builder_digest",
        "canonicalization_epoch",
        "schema_epoch",
        "distribution_epoch",
        "owner_snapshots"
      ],
      "properties": {
        "builder_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "canonicalization_epoch": {
          "type": "string",
          "minLength": 1
        },
        "schema_epoch": {
          "type": "string",
          "minLength": 1
        },
        "distribution_epoch": {
          "type": "string",
          "minLength": 1
        },
        "owner_snapshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["owner", "source_snapshot"],
            "properties": {
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "source_snapshot": {
                "type": "string",
                "pattern": "^git-tree:(?:[0-9a-f]{40}|[0-9a-f]{64})$"
              }
            }
          }
        }
      }
    },
    "payload_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "coverage": {
      "$ref": "repo-local-kag-coverage.schema.json"
    }
  }
}
