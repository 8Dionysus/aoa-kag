{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/repo-local-kag-retrieval-bundle.schema.json",
  "title": "AoA repo-local KAG retrieval bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_identity",
    "projection_identity",
    "federation_identity",
    "canonical_inputs",
    "projection_lanes",
    "retrieval_profile",
    "embedding_profile",
    "summary",
    "federation_summary",
    "files"
  ],
  "properties": {
    "schema_version": {"const": "aoa-repo-local-kag-retrieval-bundle-v1"},
    "bundle_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "content_digest"],
      "properties": {
        "local_id": {"const": "bundle:os-abyss:repo-self-retrieval"},
        "content_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "projection_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "content_digest"],
      "properties": {
        "local_id": {"const": "projection:os-abyss:repo-self-retrieval"},
        "content_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "federation_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "content_digest"],
      "properties": {
        "local_id": {"const": "projection:os-abyss:repo-self-federation"},
        "content_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "canonical_inputs": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "projection_lanes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {"enum": ["exact", "lexical", "vector", "hybrid", "graph"]}
    },
    "retrieval_profile": {"type": "object"},
    "embedding_profile": {"type": "object"},
    "summary": {
      "type": "object",
      "required": ["owner_count", "document_count", "text_bytes"],
      "properties": {
        "owner_count": {"type": "integer", "minimum": 1},
        "document_count": {"type": "integer", "minimum": 0},
        "text_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "federation_summary": {
      "type": "object",
      "required": ["owner_count", "node_count", "relation_count", "unresolved_reference_count"],
      "properties": {
        "owner_count": {"type": "integer", "minimum": 1},
        "node_count": {"type": "integer", "minimum": 0},
        "relation_count": {"type": "integer", "minimum": 0},
        "unresolved_reference_count": {"const": 0}
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owners", "nodes", "relations", "external_references", "documents"],
      "properties": {
        "owners": {"$ref": "#/$defs/file"},
        "nodes": {"$ref": "#/$defs/file"},
        "relations": {"$ref": "#/$defs/file"},
        "external_references": {"$ref": "#/$defs/file"},
        "documents": {"$ref": "#/$defs/file"}
      }
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "media_type", "sha256", "bytes", "record_count"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "media_type": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/digest"},
        "bytes": {"type": "integer", "minimum": 0},
        "record_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
