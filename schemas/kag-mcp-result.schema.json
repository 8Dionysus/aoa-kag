{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/kag-mcp-result.schema.json",
  "title": "AoA KAG MCP result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "operation", "status", "trace_id"],
  "properties": {
    "schema_version": {"const": "aoa-kag-mcp-result-v1"},
    "operation": {"enum": ["search", "read", "traverse", "explain"]},
    "status": {"enum": ["ok", "degraded", "empty"]},
    "trace_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$"
    },
    "query": {"type": "object"},
    "route": {"$ref": "#/$defs/route"},
    "projection": {"$ref": "#/$defs/projection"},
    "page": {"$ref": "#/$defs/page"},
    "results": {
      "type": "array",
      "items": {"$ref": "#/$defs/hit"}
    },
    "resources": {"$ref": "#/$defs/envelopeResources"},
    "resource": {"$ref": "#/$defs/readResource"},
    "detail": {"enum": ["compact", "summary", "full"]},
    "explanation": {"type": ["object", "null"]}
  },
  "allOf": [
    {
      "if": {"properties": {"operation": {"const": "search"}}},
      "then": {"required": ["query", "route", "projection", "page", "results", "resources"]}
    },
    {
      "if": {"properties": {"operation": {"const": "traverse"}}},
      "then": {"required": ["query", "route", "projection", "page", "results", "resources"]}
    },
    {
      "if": {"properties": {"operation": {"const": "read"}}},
      "then": {"required": ["route", "projection", "resource", "resources"]}
    },
    {
      "if": {"properties": {"operation": {"const": "explain"}}},
      "then": {"required": ["detail", "explanation", "resources"]}
    }
  ],
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "digest": {
      "type": "string",
      "oneOf": [{"const": ""}, {"pattern": "^[a-f0-9]{64}$"}]
    },
    "uri": {"type": "string", "pattern": "^aoa-kag://"},
    "recordClass": {
      "enum": ["artifact", "anchor", "entity", "event", "assertion", "relation"]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter"],
      "properties": {
        "adapter": {"$ref": "#/$defs/nonEmptyString"},
        "latency_ms": {"type": "number", "minimum": 0}
      }
    },
    "degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "state", "fallback"],
      "properties": {
        "target": {"$ref": "#/$defs/nonEmptyString"},
        "state": {"$ref": "#/$defs/nonEmptyString"},
        "fallback": {"$ref": "#/$defs/nonEmptyString"},
        "reason": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {"$ref": "#/$defs/nonEmptyString"},
        "requested_strategy": {
          "enum": ["auto", "exact", "lexical", "semantic", "hybrid", "graph"]
        },
        "used_strategy": {
          "enum": ["exact", "lexical", "semantic", "hybrid", "graph"]
        },
        "adapters": {
          "type": "array",
          "items": {"$ref": "#/$defs/adapter"}
        },
        "degradation": {
          "type": "array",
          "items": {"$ref": "#/$defs/degradation"}
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["digest", "targets"],
      "properties": {
        "digest": {"$ref": "#/$defs/digest"},
        "bundle_digest": {"$ref": "#/$defs/digest"},
        "federation_digest": {"$ref": "#/$defs/digest"},
        "updated_at": {"type": ["string", "null"]},
        "targets": {"type": "object"}
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit", "offset", "count", "next_cursor"],
      "properties": {
        "limit": {"type": "integer", "minimum": 1, "maximum": 10},
        "offset": {"type": "integer", "minimum": 0},
        "count": {"type": "integer", "minimum": 0},
        "next_cursor": {"type": ["string", "null"]}
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {"$ref": "#/$defs/nonEmptyString"},
        "runtime_source_digest": {"$ref": "#/$defs/digest"},
        "canonical_source_digest": {"$ref": "#/$defs/digest"},
        "canonical_error": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "contentInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "finding_count", "findings", "truncated"],
      "properties": {
        "state": {"const": "flagged"},
        "finding_count": {"type": "integer", "minimum": 1},
        "findings": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "offset", "code_point", "category", "name"],
            "properties": {
              "field": {"enum": ["label", "path", "snippet", "text"]},
              "offset": {"type": "integer", "minimum": 0},
              "code_point": {"type": "string", "pattern": "^U\\+[A-F0-9]{4,6}$"},
              "category": {"type": "string", "pattern": "^C[a-z]$"},
              "name": {"$ref": "#/$defs/nonEmptyString"}
            }
          }
        },
        "truncated": {"type": "boolean"}
      }
    },
    "access": {
      "type": "object",
      "additionalProperties": true,
      "required": ["scope"],
      "properties": {
        "scope": {"enum": ["public", "private", "local", "runtime"]}
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "lexical_rank", "semantic", "hybrid"],
      "properties": {
        "total": {"type": "number", "minimum": 0},
        "lexical_rank": {"type": ["number", "null"]},
        "semantic": {"type": ["number", "null"]},
        "hybrid": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0}
        }
      }
    },
    "evidencePath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "source_id",
        "target_id",
        "depth",
        "nodes",
        "relations",
        "anchor_ids"
      ],
      "properties": {
        "path_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_id": {"$ref": "#/$defs/nonEmptyString"},
        "target_id": {"$ref": "#/$defs/nonEmptyString"},
        "depth": {"type": "integer", "minimum": 1, "maximum": 4},
        "nodes": {"type": "array", "items": {"type": "object"}},
        "relations": {"type": "array", "items": {"type": "object"}},
        "anchor_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/nonEmptyString"}
        }
      }
    },
    "hitResources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record", "projection"],
      "properties": {
        "record": {"$ref": "#/$defs/uri"},
        "projection": {"$ref": "#/$defs/uri"},
        "document": {"$ref": "#/$defs/uri"},
        "source": {"$ref": "#/$defs/uri"},
        "anchors": {
          "type": "array",
          "items": {"$ref": "#/$defs/uri"}
        }
      }
    },
    "hit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qualified_id",
        "owner",
        "record_class",
        "kind",
        "label",
        "path",
        "document_role",
        "surface_state",
        "locator",
        "source_record_ids",
        "source_anchors",
        "provenance",
        "trust",
        "temporal",
        "freshness",
        "abi",
        "signs",
        "access",
        "strategy",
        "score",
        "projection_digest",
        "resources",
        "detail"
      ],
      "properties": {
        "qualified_id": {
          "type": "string",
          "pattern": "^aoa:[A-Za-z0-9_.-]+:[A-Za-z0-9_.-]+:.+$"
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "namespace"],
          "properties": {
            "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
            "namespace": {"type": "string", "pattern": "^aoa:[A-Za-z0-9_.-]+$"}
          }
        },
        "record_class": {"$ref": "#/$defs/recordClass"},
        "kind": {"$ref": "#/$defs/nonEmptyString"},
        "label": {"type": ["string", "null"]},
        "path": {"type": ["string", "null"]},
        "document_role": {"type": "string", "minLength": 1},
        "surface_state": {"type": "string", "minLength": 1},
        "locator": {"type": "object"},
        "source_record_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "source_anchors": {
          "type": "array",
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "provenance": {"type": "object"},
        "trust": {"type": "object"},
        "temporal": {"type": "object"},
        "freshness": {"$ref": "#/$defs/freshness"},
        "abi": {"type": "object"},
        "signs": {"type": "object"},
        "access": {"$ref": "#/$defs/access"},
        "strategy": {"enum": ["exact", "lexical", "semantic", "hybrid", "graph"]},
        "score": {"$ref": "#/$defs/score"},
        "projection_digest": {"$ref": "#/$defs/digest"},
        "resources": {"$ref": "#/$defs/hitResources"},
        "detail": {"enum": ["compact", "summary", "full"]},
        "snippet": {"type": "string"},
        "text": {"type": "string"},
        "text_chars": {"type": "integer", "minimum": 0},
        "text_truncated": {"type": "boolean"},
        "record": {"type": "object"},
        "sources": {"type": "array", "items": {"type": "object"}},
        "evidence_path": {"$ref": "#/$defs/evidencePath"},
        "content_inspection": {"$ref": "#/$defs/contentInspection"}
      }
    },
    "envelopeResources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence"],
      "properties": {
        "evidence": {"$ref": "#/$defs/uri"},
        "projection": {"$ref": "#/$defs/uri"}
      }
    },
    "readResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "detail", "payload"],
      "properties": {
        "uri": {"$ref": "#/$defs/uri"},
        "detail": {"enum": ["compact", "summary", "full"]},
        "payload": {}
      }
    }
  }
}
