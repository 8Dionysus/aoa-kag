  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "release_id": {
      "type": "string"
    },
    "pattern": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotion_status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
