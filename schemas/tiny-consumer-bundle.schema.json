{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/tiny-consumer-bundle.schema.json",
  "title": "AoA KAG tiny consumer bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "bundle_type",
    "source_manifest_ref",
    "source_inputs",
    "bundle_item_count",
    "bundle_items",
    "deferred_counterpart"
  ],
  "properties": {
    "bundle_version": {
      "type": "integer",
      "const": 1
    },
    "bundle_type": {
      "type": "string",
      "const": "tiny_consumer_bundle"
    },
    "source_manifest_ref": {
      "type": "string",
      "const": "manifests/tiny_consumer_bundle.json"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "role",
          "ref"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "const": "aoa-kag"
          },
          "role": {
            "type": "string",
            "enum": [
              "generated_surface",
              "consumer_doc",
              "counterpart_contract"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bundle_item_count": {
      "type": "integer",
      "minimum": 7
    },
    "bundle_items": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "name",
          "role",
          "ref"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "generated_surface",
              "consumer_doc",
              "counterpart_contract"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "deferred_counterpart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_status",
        "posture",
        "allowed_refs",
        "forbidden_active_payload_refs",
        "forbidden_interpretations"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "const": "AOA-K-0008"
        },
        "surface_status": {
          "type": "string",
          "const": "planned"
        },
        "posture": {
          "type": "string",
          "const": "planned_contract_only"
        },
        "allowed_refs": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_active_payload_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_interpretations": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "active_retrieval_payload",
              "active_projection_payload"
            ]
          }
        }
      }
    }
  }
}
