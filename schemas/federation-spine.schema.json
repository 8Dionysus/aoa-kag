{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/federation-spine.schema.json",
  "title": "AoA federation spine pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_version",
    "pack_type",
    "source_manifest_ref",
    "source_inputs",
    "repo_count",
    "repos",
    "bounded_output_contract"
  ],
  "properties": {
    "pack_version": {
      "type": "integer",
      "const": 1
    },
    "pack_type": {
      "type": "string",
      "const": "federation_spine"
    },
    "source_manifest_ref": {
      "type": "string",
      "const": "manifests/federation_spine.json"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "role",
          "ref"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "role": {
            "type": "string",
            "minLength": 2
          },
          "ref": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "repo_count": {
      "type": "integer",
      "minimum": 1
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "pilot_posture",
          "export_ref",
          "kind",
          "object_id",
          "entry_surface_ref",
          "adjunct_surfaces",
          "summary_50",
          "provenance_note",
          "non_identity_boundary"
        ],
        "properties": {
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "pilot_posture": {
            "type": "string",
            "minLength": 3
          },
          "export_ref": {
            "type": "string",
            "minLength": 3
          },
          "kind": {
            "type": "string",
            "minLength": 2
          },
          "object_id": {
            "type": "string",
            "minLength": 2
          },
          "entry_surface_ref": {
            "type": "string",
            "minLength": 3
          },
          "adjunct_surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "surface_id",
                "surface_name",
                "surface_ref",
                "match_key",
                "target_value",
                "route_id"
              ],
              "properties": {
                "surface_id": {
                  "type": "string",
                  "minLength": 3
                },
                "surface_name": {
                  "type": "string",
                  "minLength": 3
                },
                "surface_ref": {
                  "type": "string",
                  "minLength": 3
                },
                "match_key": {
                  "type": "string",
                  "minLength": 3
                },
                "target_value": {
                  "type": "string",
                  "minLength": 3
                },
                "route_id": {
                  "type": "string",
                  "minLength": 3
                }
              }
            }
          },
          "summary_50": {
            "type": "string",
            "minLength": 10
          },
          "provenance_note": {
            "type": "string",
            "minLength": 10
          },
          "non_identity_boundary": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "bounded_output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_trace_required",
        "source_replacement",
        "routing_ownership",
        "canon_authorship",
        "full_federation_claim"
      ],
      "properties": {
        "source_trace_required": {
          "type": "boolean"
        },
        "source_replacement": {
          "type": "string",
          "minLength": 3
        },
        "routing_ownership": {
          "type": "string",
          "minLength": 3
        },
        "canon_authorship": {
          "type": "string",
          "minLength": 3
        },
        "full_federation_claim": {
          "type": "string",
          "minLength": 3
        }
      }
    }
  }
}
