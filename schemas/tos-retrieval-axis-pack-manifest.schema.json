{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/tos-retrieval-axis-pack-manifest.schema.json",
  "title": "AoA KAG ToS retrieval axis pack manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "pack_type",
    "source_inputs",
    "surface_bindings",
    "output_paths",
    "bounded_output_contract"
  ],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "pack_type": {
      "type": "string",
      "const": "tos_retrieval_axis_pack"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "path",
          "role"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "path": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "enum": [
              "chunk_map",
              "bridge_doctrine",
              "bridge_surface",
              "bridge_envelope",
              "memo_chunk_face",
              "memo_graph_face",
              "tos_contract",
              "authority_surface",
              "lineage_surface"
            ]
          }
        }
      }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "surface_name",
          "derived_kind",
          "derived_slot",
          "source_input"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "pattern": "^AOA-K-[0-9]{4}$"
          },
          "surface_name": {
            "type": "string",
            "const": "tos-retrieval-axis-surface"
          },
          "derived_kind": {
            "type": "string",
            "const": "retrieval_surface"
          },
          "derived_slot": {
            "type": "string",
            "const": "axes"
          },
          "source_input": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "output_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full",
        "min"
      ],
      "properties": {
        "full": {
          "type": "string",
          "minLength": 3
        },
        "min": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "bounded_output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_trace_required",
        "source_replacement",
        "scoring_or_ranking",
        "routing_ownership",
        "graph_normalization"
      ],
      "properties": {
        "source_trace_required": {
          "type": "boolean",
          "const": true
        },
        "source_replacement": {
          "type": "string",
          "const": "forbidden"
        },
        "scoring_or_ranking": {
          "type": "string",
          "const": "forbidden"
        },
        "routing_ownership": {
          "type": "string",
          "const": "forbidden"
        },
        "graph_normalization": {
          "type": "string",
          "const": "forbidden"
        }
      }
    }
  }
}
