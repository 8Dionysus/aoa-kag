{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/repo-local-kag-coverage.schema.json",
  "title": "AoA repo-local KAG coverage report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_contract",
    "root",
    "coverage_summary",
    "owners"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa-repo-local-kag-coverage-v1"
    },
    "source_contract": {
      "const": "schemas/repo-local-kag-index.schema.json"
    },
    "root": {
      "const": "aoa-os:canonical-providers"
    },
    "coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_count",
        "passed",
        "migration_needed",
        "missing",
        "owner_specific",
        "measured_owner_count",
        "self_excluded_owner_count"
      ],
      "properties": {
        "owner_count": {
          "type": "integer",
          "minimum": 1
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "migration_needed": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "owner_specific": {
          "type": "integer",
          "minimum": 0
        },
        "measured_owner_count": {
          "type": "integer",
          "minimum": 0
        },
        "self_excluded_owner_count": {
          "type": "integer",
          "minimum": 0
        },
        "portable_v3": {
          "type": "integer",
          "minimum": 0
        },
        "tiered_v4": {
          "type": "integer",
          "minimum": 0
        },
        "portable_tracked_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "git_hot_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "corpus_total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_cold_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "os_aggregate_tracked_bytes_max": {
          "const": 335544320
        },
        "os_git_hot_target_bytes": {
          "const": 234881024
        },
        "aggregate_budget_state": {
          "enum": [
            "partial",
            "passed",
            "exceeded"
          ]
        },
        "target_budget_state": {
          "enum": [
            "partial",
            "passed",
            "exceeded"
          ]
        }
      }
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ownerCoverage"
      }
    }
  },
  "$defs": {
    "repositoryIndexFamily": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {"const": "kag/indexes/source_surface_index.json"},
        "entity": {"const": "kag/indexes/repo_entity_index.json"},
        "artifact": {"const": "kag/indexes/repo_artifact_index.json"},
        "anchor": {"const": "kag/indexes/repo_anchor_index.json"},
        "event": {"const": "kag/indexes/repo_event_index.json"},
        "assertion": {"const": "kag/indexes/repo_assertion_index.json"},
        "relation": {"const": "kag/indexes/repo_relation_index.json"}
      }
    },
    "ownerCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "owner_type",
        "root",
        "kag_home",
        "index_status",
        "index_files",
        "repository_index_family",
        "domain_index_catalog_ref",
        "coverage"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "owner_type": {
          "type": "string",
          "enum": [
            "center",
            "organ",
            "connector",
            "bundle_provider",
            "runtime_source",
            "runtime_mirror",
            "workspace",
            "unknown"
          ]
        },
        "root": {
          "type": "string",
          "pattern": "^aoa-owner:[A-Za-z0-9_.-]+$"
        },
        "kag_home": {
          "type": "string",
          "pattern": "^(|aoa-owner:[A-Za-z0-9_.-]+:kag)$"
        },
        "index_status": {
          "type": "string",
          "enum": [
            "passed",
            "migration-needed",
            "missing",
            "owner-specific"
          ]
        },
        "index_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "family_storage": {
          "enum": [
            "v2-monoliths",
            "v3-portable-shards",
            "v4-tiered-content-addressed",
            "none"
          ]
        },
        "portable_family": {
          "$ref": "#/$defs/portableFamily"
        },
        "repository_index_family": {
          "$ref": "#/$defs/repositoryIndexFamily"
        },
        "domain_index_catalog_ref": {
          "type": "string",
          "enum": ["", "kag/indexes/domain_index_catalog.json"]
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "documents",
            "mechanics",
            "commands",
            "validators",
            "tests",
            "scripts",
            "schemas",
            "generated"
          ],
          "properties": {
            "documents": {
              "type": "integer",
              "minimum": 0
            },
            "mechanics": {
              "type": "integer",
              "minimum": 0
            },
            "commands": {
              "type": "integer",
              "minimum": 0
            },
            "validators": {
              "type": "integer",
              "minimum": 0
            },
            "tests": {
              "type": "integer",
              "minimum": 0
            },
            "scripts": {
              "type": "integer",
              "minimum": 0
            },
            "schemas": {
              "type": "integer",
              "minimum": 0
            },
            "generated": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "common_surface_profile": {
          "$ref": "#/$defs/commonSurfaceProfile"
        }
      }
    },
    "portableFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_ref",
        "content_digest",
        "digest_state",
        "tracked_bytes",
        "tracked_bytes_max",
        "shards",
        "budget_state",
        "receipt_ref",
        "corpus_digest",
        "distribution_digest",
        "git_hot_bytes",
        "corpus_total_bytes",
        "artifact_cold_bytes",
        "git_hot_objects",
        "artifact_cold_objects",
        "placement_state",
        "hot_profile_ref",
        "artifact_locator_ref",
        "os_git_hot_target_bytes",
        "aggregate_ceiling_receiptable_by_owner",
        "measurement_state",
        "measurement_ref"
      ],
      "properties": {
        "manifest_ref": {
          "enum": [
            "",
            "kag/indexes/index_family.manifest.json"
          ]
        },
        "content_digest": {
          "type": "string",
          "pattern": "^(|[a-f0-9]{64})$"
        },
        "digest_state": {
          "enum": [
            "published",
            "self-manifest",
            "not-applicable"
          ]
        },
        "tracked_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "tracked_bytes_max": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50331648
        },
        "shards": {
          "type": "integer",
          "minimum": 0
        },
        "budget_state": {
          "enum": [
            "passed",
            "receipted",
            "self-excluded",
            "not-applicable"
          ]
        },
        "receipt_ref": {
          "type": "string",
          "pattern": "^(|kag/receipts/index_family_budget/[a-f0-9]{64}\\.json)$"
        },
        "corpus_digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-f0-9]{64})$"
        },
        "distribution_digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-f0-9]{64})$"
        },
        "git_hot_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "corpus_total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_cold_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "git_hot_objects": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_cold_objects": {
          "type": "integer",
          "minimum": 0
        },
        "placement_state": {
          "enum": ["not-applicable", "git-full", "shadow", "externalized"]
        },
        "hot_profile_ref": {
          "enum": ["", "kag/indexes/hot_profile.json"]
        },
        "artifact_locator_ref": {
          "enum": ["", "kag/indexes/artifact_locators.json"]
        },
        "os_git_hot_target_bytes": {
          "const": 234881024
        },
        "aggregate_ceiling_receiptable_by_owner": {
          "const": false
        },
        "measurement_state": {
          "enum": ["measured", "self-excluded", "not-applicable"]
        },
        "measurement_ref": {
          "enum": ["", "owner-family-release.json#/measurements"]
        }
      }
    },
    "commonSurfaceProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "counts",
        "quality"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "source_surface_index",
            "source_tree_scan"
          ]
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_kind",
            "primary_kind",
            "surface_state",
            "document_role",
            "mechanics_role",
            "command_role"
          ],
          "properties": {
            "artifact_kind": {"$ref": "#/$defs/countMap"},
            "primary_kind": {"$ref": "#/$defs/countMap"},
            "surface_state": {"$ref": "#/$defs/countMap"},
            "document_role": {"$ref": "#/$defs/countMap"},
            "mechanics_role": {"$ref": "#/$defs/countMap"},
            "command_role": {"$ref": "#/$defs/countMap"}
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "unknown_count",
            "has_kag_home",
            "has_record_classes",
            "has_source_index",
            "has_owner_commands",
            "has_generated_readmodels",
            "has_validation_route"
          ],
          "properties": {
            "unknown_count": {"type": "integer", "minimum": 0},
            "has_kag_home": {"type": "boolean"},
            "has_record_classes": {"type": "boolean"},
            "has_source_index": {"type": "boolean"},
            "has_owner_commands": {"type": "boolean"},
            "has_generated_readmodels": {"type": "boolean"},
            "has_validation_route": {"type": "boolean"}
          }
        }
      }
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
