{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/repo-local-kag-coverage.schema.json",
  "title": "AoA repo-local KAG coverage report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_contract",
    "root",
    "coverage_summary",
    "owners"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa-repo-local-kag-coverage-v1"
    },
    "source_contract": {
      "const": "schemas/repo-local-kag-index.schema.json"
    },
    "root": {
      "type": "string",
      "minLength": 1
    },
    "coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_count",
        "passed",
        "migration_needed",
        "missing",
        "owner_specific"
      ],
      "properties": {
        "owner_count": {
          "type": "integer",
          "minimum": 1
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "migration_needed": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "owner_specific": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ownerCoverage"
      }
    }
  },
  "$defs": {
    "ownerCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "owner_type",
        "root",
        "kag_home",
        "index_status",
        "index_files",
        "coverage"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "owner_type": {
          "type": "string",
          "enum": [
            "center",
            "organ",
            "connector",
            "bundle_provider",
            "runtime_source",
            "runtime_mirror",
            "workspace",
            "unknown"
          ]
        },
        "root": {
          "type": "string",
          "minLength": 1
        },
        "kag_home": {
          "type": "string"
        },
        "index_status": {
          "type": "string",
          "enum": [
            "passed",
            "migration-needed",
            "missing",
            "owner-specific"
          ]
        },
        "index_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "documents",
            "mechanics",
            "commands",
            "validators",
            "tests",
            "scripts",
            "schemas",
            "generated"
          ],
          "properties": {
            "documents": {
              "type": "integer",
              "minimum": 0
            },
            "mechanics": {
              "type": "integer",
              "minimum": 0
            },
            "commands": {
              "type": "integer",
              "minimum": 0
            },
            "validators": {
              "type": "integer",
              "minimum": 0
            },
            "tests": {
              "type": "integer",
              "minimum": 0
            },
            "scripts": {
              "type": "integer",
              "minimum": 0
            },
            "schemas": {
              "type": "integer",
              "minimum": 0
            },
            "generated": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "common_surface_profile": {
          "$ref": "#/$defs/commonSurfaceProfile"
        }
      }
    },
    "commonSurfaceProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "counts",
        "quality"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "source_surface_index",
            "source_tree_scan"
          ]
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_kind",
            "primary_kind",
            "surface_state",
            "document_role",
            "mechanics_role",
            "command_role"
          ],
          "properties": {
            "artifact_kind": {"$ref": "#/$defs/countMap"},
            "primary_kind": {"$ref": "#/$defs/countMap"},
            "surface_state": {"$ref": "#/$defs/countMap"},
            "document_role": {"$ref": "#/$defs/countMap"},
            "mechanics_role": {"$ref": "#/$defs/countMap"},
            "command_role": {"$ref": "#/$defs/countMap"}
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "unknown_count",
            "has_kag_home",
            "has_record_classes",
            "has_source_index",
            "has_owner_commands",
            "has_generated_readmodels",
            "has_validation_route"
          ],
          "properties": {
            "unknown_count": {"type": "integer", "minimum": 0},
            "has_kag_home": {"type": "boolean"},
            "has_record_classes": {"type": "boolean"},
            "has_source_index": {"type": "boolean"},
            "has_owner_commands": {"type": "boolean"},
            "has_generated_readmodels": {"type": "boolean"},
            "has_validation_route": {"type": "boolean"}
          }
        }
      }
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
