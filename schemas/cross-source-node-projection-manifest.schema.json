{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/cross-source-node-projection-manifest.schema.json",
  "title": "AoA KAG cross-source node projection manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "pack_type",
    "source_inputs",
    "surface_bindings",
    "output_paths",
    "bounded_output_contract"
  ],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "pack_type": {
      "type": "string",
      "const": "cross_source_node_projection"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "path",
          "role"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "path": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "enum": [
              "primary_export",
              "supporting_export",
              "retrieval_axis",
              "federation_spine"
            ]
          }
        }
      }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "surface_name",
          "derived_kind",
          "derived_slot",
          "source_input"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "pattern": "^AOA-K-[0-9]{4}$"
          },
          "surface_name": {
            "type": "string",
            "const": "cross-source-node-projection"
          },
          "derived_kind": {
            "type": "string",
            "const": "node_projection"
          },
          "derived_slot": {
            "type": "string",
            "const": "projections"
          },
          "source_input": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "output_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full",
        "min"
      ],
      "properties": {
        "full": {
          "type": "string",
          "minLength": 3
        },
        "min": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "bounded_output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_trace_required",
        "source_replacement",
        "counterpart_activation",
        "graph_expansion",
        "routing_ownership"
      ],
      "properties": {
        "source_trace_required": {
          "type": "boolean",
          "const": true
        },
        "source_replacement": {
          "type": "string",
          "const": "forbidden"
        },
        "counterpart_activation": {
          "type": "string",
          "const": "forbidden"
        },
        "graph_expansion": {
          "type": "string",
          "const": "forbidden"
        },
        "routing_ownership": {
          "type": "string",
          "const": "forbidden"
        }
      }
    }
  }
}
