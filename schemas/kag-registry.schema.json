{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/kag-registry.schema.json",
  "title": "AoA KAG registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "layer", "artifact_identity", "surfaces"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-kag"
    },
    "artifact_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "properties": {
        "artifact_class": {
          "type": "string",
          "const": "derived_kag_registry_readmodel_bundle"
        },
        "surface_state": {
          "type": "string",
          "const": "public_generated_kag_registry"
        },
        "owner_repo": {
          "type": "string",
          "const": "aoa-kag"
        },
        "authority_ref": {
          "type": "string",
          "const": "docs/KAG_MODEL.md"
        },
        "producer": {
          "type": "string",
          "const": "scripts/generate_kag.py from manifests/kag_registry.json"
        },
        "consumer_expectation": {
          "type": "string",
          "minLength": 40
        },
        "privacy_boundary": {
          "type": "string",
          "minLength": 40
        },
        "content_identity": {
          "type": "string",
          "const": "generated/kag_registry.json and generated/kag_registry.min.json rebuilt from manifests/kag_registry.json and compared by validate_kag"
        },
        "abi_epoch": {
          "type": "string",
          "const": "aoa_kag_registry_readmodel_v1"
        },
        "contract_version": {
          "type": "string",
          "const": "schemas/kag-registry.schema.json@aoa_kag_registry_readmodel_v1#artifact_identity"
        },
        "trust_layer": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {"const": "abi_contract_signature"},
            {"const": "sbom"},
            {"const": "slsa_in_toto"}
          ]
        },
        "verification": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {"const": "python scripts/validate_kag.py"},
            {"const": "python scripts/ci_gate.py --mode generated"},
            {"const": "python scripts/validate_abyss_machine_kag_registry_bundle.py"}
          ]
        },
        "action": {
          "type": "string",
          "const": "ADD_RELEASE_PROVENANCE"
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status",
          "summary",
          "source_class",
          "derived_kind",
          "provenance_mode",
          "normalization_scope",
          "framework_readiness",
          "source_repos"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 3},
          "name": {"type": "string", "minLength": 3},
          "status": {"type": "string", "enum": ["active", "planned", "experimental", "deprecated"]},
          "summary": {"type": "string", "minLength": 10},
          "source_class": {"type": "string", "enum": ["technique_bundle", "skill_bundle", "eval_bundle", "playbook_bundle", "memo_object", "tos_text", "review_surface"]},
          "source_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["repo", "source_class", "role"],
              "properties": {
                "repo": {"type": "string", "minLength": 2},
                "source_class": {"type": "string", "enum": ["technique_bundle", "skill_bundle", "eval_bundle", "playbook_bundle", "memo_object", "tos_text", "review_surface"]},
                "role": {"type": "string", "enum": ["primary", "supporting"]}
              }
            }
          },
          "derived_kind": {"type": "string", "enum": ["section_manifest", "metadata_spine", "relation_view", "provenance_view", "chunk_map", "node_projection", "edge_projection", "retrieval_surface"]},
          "provenance_mode": {"type": "string", "enum": ["strict_source_linked", "bounded_source_linked", "derived_with_handles"]},
          "normalization_scope": {"type": "string", "minLength": 3},
          "framework_readiness": {"type": "string", "enum": ["neutral", "hipporag_ready", "llamaindex_ready", "multi_consumer_ready"]},
          "source_repos": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 2}
          }
        }
      }
    }
  }
}
