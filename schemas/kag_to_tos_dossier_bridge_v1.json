{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/kag_to_tos_dossier_bridge_v1.json",
  "title": "kag_to_tos_dossier_bridge_v1",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "status",
    "summary",
    "evidence_refs",
    "payload",
    "owner_repo"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "kag_to_tos_dossier_bridge"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "captured",
        "candidate",
        "review",
        "approved",
        "blocked",
        "rejected",
        "promoted",
        "active",
        "retired",
        "scheduled",
        "passed",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "payload": {
      "type": "object",
      "required": [
        "kag_node_id",
        "tos_dossier_id",
        "direct_write"
      ],
      "additionalProperties": false,
      "properties": {
        "kag_node_id": {
          "type": "string"
        },
        "tos_dossier_id": {
          "type": "string"
        },
        "direct_write": {
          "type": "boolean",
          "const": false
        }
      }
    }
  },
  "additionalProperties": false
}
