{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/technique-lift-pack.schema.json",
  "title": "AoA KAG technique lift pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_version",
    "pack_type",
    "source_repo",
    "source_manifest_ref",
    "source_inputs",
    "surface_bindings",
    "section_scope",
    "technique_count",
    "techniques"
  ],
  "properties": {
    "pack_version": {
      "type": "integer",
      "const": 1
    },
    "pack_type": {
      "type": "string",
      "const": "technique_lift_pack"
    },
    "source_repo": {
      "type": "string",
      "const": "aoa-techniques"
    },
    "source_manifest_ref": {
      "type": "string",
      "const": "manifests/technique_lift_pack.json"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "ref"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "surface_name",
          "derived_kind",
          "derived_slot",
          "source_input"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "pattern": "^AOA-K-[0-9]{4}$"
          },
          "surface_name": {
            "type": "string",
            "minLength": 3
          },
          "derived_kind": {
            "type": "string",
            "minLength": 3
          },
          "derived_slot": {
            "type": "string",
            "minLength": 3
          },
          "source_input": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "section_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "technique_count": {
      "type": "integer",
      "minimum": 1
    },
    "techniques": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "technique_id",
          "technique_name",
          "source_ref",
          "section_lift",
          "metadata_spine",
          "relation_view",
          "provenance_view"
        ],
        "properties": {
          "technique_id": {
            "type": "string",
            "pattern": "^AOA-T-[0-9]{4}$"
          },
          "technique_name": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "section_lift": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section_count",
              "sections"
            ],
            "properties": {
              "section_count": {
                "type": "integer",
                "minimum": 1
              },
              "sections": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "heading",
                    "order"
                  ],
                  "properties": {
                    "heading": {
                      "type": "string",
                      "minLength": 1
                    },
                    "order": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              }
            }
          },
          "metadata_spine": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "domain",
              "status",
              "summary",
              "maturity_score",
              "rigor_level",
              "reversibility",
              "review_required",
              "validation_strength",
              "export_ready"
            ],
            "properties": {
              "domain": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "maturity_score": {
                "type": "integer",
                "minimum": 0
              },
              "rigor_level": {
                "type": "string",
                "minLength": 1
              },
              "reversibility": {
                "type": "string",
                "minLength": 1
              },
              "review_required": {
                "type": "boolean"
              },
              "validation_strength": {
                "type": "string",
                "minLength": 1
              },
              "export_ready": {
                "type": "boolean"
              }
            }
          },
          "relation_view": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "relation_count",
              "relations"
            ],
            "properties": {
              "relation_count": {
                "type": "integer",
                "minimum": 0
              },
              "relations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "relation_type",
                    "target_ref"
                  ],
                  "properties": {
                    "relation_type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "target_ref": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "provenance_view": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "public_safety_reviewed_at",
              "note_count",
              "note_handles"
            ],
            "properties": {
              "public_safety_reviewed_at": {
                "type": "string",
                "minLength": 1
              },
              "note_count": {
                "type": "integer",
                "minimum": 0
              },
              "note_handles": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "kind",
                    "title",
                    "note_ref"
                  ],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "note_ref": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
