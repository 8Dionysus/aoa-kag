{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/bridge-retrieval-surface.schema.json",
  "title": "AoA-ToS bridge retrieval surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_id",
    "source_refs",
    "lineage_refs",
    "axis_summary"
  ],
  "properties": {
    "surface_id": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "lineage_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "practice_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "axis_summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
