{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/kag-mcp-capabilities.schema.json",
  "title": "AoA KAG MCP capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owners",
    "record_classes",
    "strategies",
    "detail_levels",
    "access_scopes",
    "limits",
    "resource_templates",
    "projection"
  ],
  "properties": {
    "schema_version": {"const": "aoa-kag-mcp-capabilities-v1"},
    "owners": {
      "type": "array",
      "items": {"$ref": "#/$defs/owner"}
    },
    "record_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/recordClass"}
    },
    "strategies": {
      "type": "array",
      "items": {"$ref": "#/$defs/strategy"}
    },
    "detail_levels": {
      "type": "array",
      "const": ["compact", "summary", "full"]
    },
    "access_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["public", "private", "local", "runtime"]}
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_size", "traversal_depth", "full_text_chars"],
      "properties": {
        "page_size": {"type": "integer", "const": 10},
        "traversal_depth": {"type": "integer", "minimum": 1},
        "full_text_chars": {"type": "integer", "minimum": 1}
      }
    },
    "resource_templates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^aoa-kag://"}
    },
    "projection": {"$ref": "#/$defs/projection"},
    "kinds": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/recordClass"},
      "additionalProperties": {
        "type": "array",
        "uniqueItems": true,
        "items": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "filters": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    }
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "digest": {
      "type": "string",
      "oneOf": [
        {"const": ""},
        {"pattern": "^[a-f0-9]{64}$"}
      ]
    },
    "recordClass": {
      "type": "string",
      "enum": ["artifact", "anchor", "entity", "event", "assertion", "relation"]
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "runtime_source_digest", "canonical_source_digest"],
      "properties": {
        "state": {
          "enum": ["current", "stale", "canonical_only", "source_unavailable", "unknown"]
        },
        "runtime_source_digest": {"$ref": "#/$defs/digest"},
        "canonical_source_digest": {"$ref": "#/$defs/digest"},
        "canonical_error": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "manifest_uri"],
      "properties": {
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
        "namespace": {"type": ["string", "null"]},
        "owner_type": {"type": ["string", "null"]},
        "record_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "relation_count": {"type": "integer", "minimum": 0},
        "runtime_source_digest": {"$ref": "#/$defs/digest"},
        "freshness": {"$ref": "#/$defs/freshness"},
        "manifest_uri": {"type": "string", "pattern": "^aoa-kag://owners/"}
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "available", "record_classes"],
      "properties": {
        "name": {"enum": ["auto", "exact", "lexical", "semantic", "hybrid", "graph"]},
        "available": {"type": "boolean"},
        "record_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/recordClass"}
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "completed_at"],
      "properties": {
        "state": {
          "enum": ["current", "passed", "missing", "mismatched", "damaged", "failed"]
        },
        "completed_at": {"type": ["string", "null"]}
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest",
        "bundle_digest",
        "federation_digest",
        "updated_at",
        "targets"
      ],
      "properties": {
        "digest": {"$ref": "#/$defs/digest"},
        "bundle_digest": {"$ref": "#/$defs/digest"},
        "federation_digest": {"$ref": "#/$defs/digest"},
        "updated_at": {"type": ["string", "null"]},
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["exact", "vector", "graph", "retrieval_eval"],
          "properties": {
            "exact": {"$ref": "#/$defs/target"},
            "vector": {"$ref": "#/$defs/target"},
            "graph": {"$ref": "#/$defs/target"},
            "retrieval_eval": {"$ref": "#/$defs/target"}
          }
        }
      }
    }
  }
}
