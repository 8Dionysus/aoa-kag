{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/counterpart-federation-exposure-review.schema.json",
  "title": "AoA KAG counterpart federation exposure review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_version",
    "review_type",
    "source_manifest_ref",
    "source_inputs",
    "surface_id",
    "surface_status",
    "review_status",
    "reviewed_surface_count",
    "reviewed_surfaces",
    "bounded_output_contract"
  ],
  "properties": {
    "review_version": {
      "type": "integer",
      "const": 1
    },
    "review_type": {
      "type": "string",
      "const": "counterpart_federation_exposure_review"
    },
    "source_manifest_ref": {
      "type": "string",
      "const": "manifests/counterpart_federation_exposure_review.json"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "role",
          "ref"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "const": "aoa-kag"
          },
          "role": {
            "type": "string",
            "enum": [
              "reviewed_surface",
              "counterpart_contract"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surface_id": {
      "type": "string",
      "const": "AOA-K-0008"
    },
    "surface_status": {
      "type": "string",
      "const": "planned"
    },
    "review_status": {
      "type": "string",
      "const": "passed_for_planned_posture"
    },
    "reviewed_surface_count": {
      "type": "integer",
      "minimum": 8
    },
    "reviewed_surfaces": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_name",
          "surface_ref",
          "exposure_posture",
          "review_note"
        ],
        "properties": {
          "surface_name": {
            "type": "string",
            "minLength": 1
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "exposure_posture": {
            "type": "string",
            "enum": [
              "contract_only_counterpart_refs",
              "planned_contract_only",
              "no_counterpart_exposure",
              "counterpart_activation_forbidden",
              "contract_reference_surface",
              "planned_contract_surface",
              "planned_example_surface"
            ]
          },
          "review_note": {
            "type": "string",
            "minLength": 20
          },
          "allowed_counterpart_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "bounded_output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "silent_federation_exposure",
        "generated_counterpart_payload_inference",
        "routing_ownership",
        "source_replacement"
      ],
      "properties": {
        "silent_federation_exposure": {
          "type": "string",
          "const": "forbidden"
        },
        "generated_counterpart_payload_inference": {
          "type": "string",
          "const": "forbidden"
        },
        "routing_ownership": {
          "type": "string",
          "const": "forbidden"
        },
        "source_replacement": {
          "type": "string",
          "const": "forbidden"
        }
      }
    }
  }
}
