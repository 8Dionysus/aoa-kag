{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/repo-local-kag-family-manifest.schema.json",
  "title": "AoA repo-local KAG portable family manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repo",
    "family_identity",
    "partitioning",
    "normalization",
    "source_index_header",
    "compatibility",
    "budgets",
    "summary",
    "shards"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa-repo-local-kag-family-manifest-v3"
    },
    "repo": {
      "$ref": "#/$defs/repo"
    },
    "family_identity": {
      "$ref": "#/$defs/familyIdentity"
    },
    "partitioning": {
      "$ref": "#/$defs/partitioning"
    },
    "normalization": {
      "$ref": "#/$defs/normalization"
    },
    "source_index_header": {
      "type": "object",
      "required": [
        "schema_version",
        "repo",
        "index_identity",
        "toolchain",
        "coverage_summary",
        "registry_output"
      ],
      "not": {
        "required": [
          "records"
        ]
      }
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "shards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/shard"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "namespace",
        "owner_type",
        "root",
        "git_ref"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "namespace": {
          "type": "string",
          "pattern": "^aoa:[a-z0-9_.-]+$"
        },
        "owner_type": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "root": {
          "const": "."
        },
        "git_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "familyIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_id",
        "artifact_kind",
        "content_digest",
        "schema_ref",
        "source_snapshot"
      ],
      "properties": {
        "local_id": {
          "const": "family:repo-local:portable-record-corpus"
        },
        "artifact_kind": {
          "const": "repo_local_kag_portable_family"
        },
        "content_digest": {
          "$ref": "#/$defs/digest"
        },
        "schema_ref": {
          "const": "aoa-kag:schemas/repo-local-kag-family-manifest.schema.json"
        },
        "source_snapshot": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "partitioning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "target_shard_bytes",
        "hard_max_shard_bytes",
        "max_record_bytes",
        "split_policy",
        "merge_policy",
        "ranges"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256-record-key-adaptive-prefix"
        },
        "target_shard_bytes": {
          "const": 131072
        },
        "hard_max_shard_bytes": {
          "const": 196608
        },
        "max_record_bytes": {
          "const": 131072
        },
        "split_policy": {
          "const": "prefix-split-only"
        },
        "merge_policy": {
          "const": "never-automatic"
        },
        "ranges": {
          "type": "object",
          "minProperties": 3,
          "additionalProperties": {
            "type": "array",
            "minItems": 16,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-f0-9]{1,64}$"
            }
          }
        }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_record_classes",
        "derived_compatibility_classes",
        "anchor_defaults",
        "chunking"
      ],
      "properties": {
        "canonical_record_classes": {
          "const": [
            "source",
            "anchor",
            "event"
          ]
        },
        "derived_compatibility_classes": {
          "const": [
            "artifact",
            "entity",
            "assertion",
            "relation"
          ]
        },
        "anchor_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_class",
            "provenance_ref",
            "temporal_ref",
            "trust_ref"
          ],
          "properties": {
            "evidence_class": {
              "const": "deterministic"
            },
            "provenance_ref": {
              "const": "deterministic"
            },
            "temporal_ref": {
              "const": "current"
            },
            "trust_ref": {
              "const": "deterministic"
            }
          }
        },
        "chunking": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "chunk_target_bytes",
            "chunkable_fields"
          ],
          "properties": {
            "strategy": {
              "const": "oversize-list-content-chunks"
            },
            "chunk_target_bytes": {
              "const": 65536
            },
            "chunkable_fields": {
              "type": "object"
            }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view",
        "assembly",
        "files"
      ],
      "properties": {
        "view": {
          "const": "aoa-repo-local-kag-v2"
        },
        "assembly": {
          "const": "deterministic-on-demand"
        },
        "files": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/compatibilityFile"
          }
        }
      }
    },
    "compatibilityFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "schema_version",
        "content_digest",
        "records"
      ],
      "properties": {
        "kind": {
          "enum": [
            "source",
            "artifact",
            "anchor",
            "entity",
            "event",
            "assertion",
            "relation"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "schema_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content_digest": {
          "$ref": "#/$defs/digest"
        },
        "records": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracked_bytes_max",
        "changed_generated_bytes_max",
        "global_tracked_bytes_max",
        "exceedance_route"
      ],
      "properties": {
        "tracked_bytes_max": {
          "type": "integer",
          "minimum": 4194304,
          "maximum": 50331648
        },
        "changed_generated_bytes_max": {
          "const": 1048576
        },
        "global_tracked_bytes_max": {
          "const": 50331648
        },
        "exceedance_route": {
          "const": "kag/receipts/index_family_budget/<family-digest>.json"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_records",
        "anchor_records",
        "event_records",
        "canonical_records",
        "shards",
        "shard_bytes",
        "tracked_bytes"
      ],
      "properties": {
        "source_records": {
          "type": "integer",
          "minimum": 1
        },
        "anchor_records": {
          "type": "integer",
          "minimum": 1
        },
        "event_records": {
          "type": "integer",
          "minimum": 1
        },
        "canonical_records": {
          "type": "integer",
          "minimum": 3
        },
        "shards": {
          "type": "integer",
          "minimum": 1
        },
        "shard_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "tracked_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "shard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "range",
        "path",
        "digest",
        "bytes",
        "records"
      ],
      "properties": {
        "kind": {
          "enum": [
            "source",
            "anchor",
            "anchor_chunk",
            "event",
            "event_chunk"
          ]
        },
        "range": {
          "type": "string",
          "pattern": "^[a-f0-9]{1,64}$"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 196608
        },
        "records": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
