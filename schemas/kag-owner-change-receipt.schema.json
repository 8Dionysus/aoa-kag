{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-kag/schemas/kag-owner-change-receipt.schema.json",
  "title": "AoA KAG owner change attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "owner", "base", "head", "changed_record_keys", "changed_shards", "changed_bytes", "changed_files", "affected_compatibility_views", "artifact_objects", "versions", "validation", "provenance"],
  "properties": {
    "schema_version": {"const": "aoa-kag-owner-change-receipt-v1"},
    "owner": {"type": "string", "minLength": 1},
    "base": {"$ref": "#/$defs/endpoint"},
    "head": {"$ref": "#/$defs/endpoint"},
    "changed_record_keys": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "changed_shards": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "changed_bytes": {"type": "integer", "minimum": 0},
    "changed_files": {"type": "integer", "minimum": 0},
    "affected_compatibility_views": {"type": "array", "items": {"enum": ["source", "artifact", "anchor", "entity", "event", "assertion", "relation"]}, "uniqueItems": true},
    "artifact_objects": {"type": "object", "required": ["added", "reused"], "properties": {"added": {"type": "array", "items": {"$ref": "#/$defs/digest"}}, "reused": {"type": "array", "items": {"$ref": "#/$defs/digest"}}}},
    "versions": {"type": "object"},
    "validation": {"type": "object"},
    "provenance": {"type": "object"}
  },
  "$defs": {"digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "endpoint": {"type": "object", "required": ["commit", "source_snapshot", "corpus_digest", "distribution_digest"], "properties": {"commit": {"type": "string", "minLength": 1}, "source_snapshot": {"type": "string", "minLength": 1}, "corpus_digest": {"$ref": "#/$defs/digest"}, "distribution_digest": {"$ref": "#/$defs/digest"}}}}
}
