{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-kag/main/schemas/tos-retrieval-axis-pack.schema.json",
  "title": "AoA KAG ToS retrieval axis pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_version",
    "pack_type",
    "source_manifest_ref",
    "source_inputs",
    "surface_bindings",
    "surface_id",
    "surface_name",
    "axis_count",
    "axes",
    "bounded_output_contract"
  ],
  "properties": {
    "pack_version": {
      "type": "integer",
      "const": 1
    },
    "pack_type": {
      "type": "string",
      "const": "tos_retrieval_axis_pack"
    },
    "source_manifest_ref": {
      "type": "string",
      "const": "manifests/tos_retrieval_axis_pack.json"
    },
    "source_inputs": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "role",
          "ref"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 2
          },
          "role": {
            "type": "string",
            "minLength": 2
          },
          "ref": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "surface_name",
          "derived_kind",
          "derived_slot",
          "source_input"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "pattern": "^AOA-K-[0-9]{4}$"
          },
          "surface_name": {
            "type": "string",
            "const": "tos-retrieval-axis-surface"
          },
          "derived_kind": {
            "type": "string",
            "const": "retrieval_surface"
          },
          "derived_slot": {
            "type": "string",
            "const": "axes"
          },
          "source_input": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surface_id": {
      "type": "string",
      "const": "AOA-K-0007"
    },
    "surface_name": {
      "type": "string",
      "const": "tos-retrieval-axis-surface"
    },
    "axis_count": {
      "type": "integer",
      "minimum": 1
    },
    "axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "axis_id",
          "source_node_id",
          "chunk_map_ref",
          "chunk_ids",
          "source_refs",
          "lineage_refs",
          "conflict_refs",
          "practice_refs",
          "bridge_surface_ref",
          "bridge_envelope_ref",
          "memo_face_refs",
          "axis_summary"
        ],
        "properties": {
          "axis_id": {
            "type": "string",
            "minLength": 3
          },
          "source_node_id": {
            "type": "string",
            "minLength": 3
          },
          "chunk_map_ref": {
            "type": "string",
            "minLength": 3
          },
          "chunk_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "lineage_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "conflict_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "practice_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "bridge_surface_ref": {
            "type": "string",
            "minLength": 3
          },
          "bridge_envelope_ref": {
            "type": "string",
            "minLength": 3
          },
          "memo_face_refs": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "axis_summary": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "bounded_output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_trace_required",
        "source_replacement",
        "scoring_or_ranking",
        "routing_ownership",
        "graph_normalization"
      ],
      "properties": {
        "source_trace_required": {
          "type": "boolean"
        },
        "source_replacement": {
          "type": "string",
          "minLength": 3
        },
        "scoring_or_ranking": {
          "type": "string",
          "minLength": 3
        },
        "routing_ownership": {
          "type": "string",
          "minLength": 3
        },
        "graph_normalization": {
          "type": "string",
          "minLength": 3
        }
      }
    }
  }
}
